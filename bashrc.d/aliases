export workdir=/home/vs-horcrux/Desktop/workdir
export dots=$workdir/dots
export projects=$workdir/projects
export maindots=$dots/hypr-setup/dotfiles/src

alias aman='cat /home/vs-horcrux/Desktop/workdir/dots/hypr-setup-robust/aesthetic-manifest'
alias fman='cat /home/vs-horcrux/Desktop/workdir/dots/hypr-setup-robust/functional-manifest'

alias dirtyfiles='sh /home/vs-horcrux/Desktop/workdir/dots/hypr-setup-robust/dirty-files.sh'

alias stopidle='killall -STOP hypridle && notify-send "Hypridle Stopped"'
alias startidle='killall -CONT hypridle && notify-send "Hypridle Resumed"'

# Add this inside one of your scripts in the storage partition
export s="/mnt/storage"
alias s="cd /mnt/storage"

alias lwd="pwd -L"
alias pwd="pwd -P"

alias space="df -h"

alias sudo="reason sudo"

alias launch-reaper='PIPEWIRE_LATENCY="128/48000" reaper & disown'


alias bashrc='source ~/.bashrc'

alias edit='flatpak run com.vscodium.codium'
