[global]
    ### --- EXPOSED VARIABLES --- ###
    
    # Geometry and Positioning
    # Width is fixed, height is dynamic (max 110)
    width = 300
    height = 110
    
    # Offset: mapping your x-gap and y-gap
    # Dunst uses "X x Y", 25px from right, 45px from top
    offset = 15x15
    origin = top-right
    
    # Padding and Spacing
    padding = 10
    horizontal_padding = 13
    
    # UI Elements
    frame_width = 2
    corner_radius = 12
    
    # Font Settings (Using your exact JetBrainsMono string)
    font = JetBrainsMonoNL Nerd Font, JetBrainsMonoNL NF ExtraBold 11
    
    # Text Alignment
    alignment = left
    vertical_alignment = center
    
    # Progress Bar (optional, for things like volume)
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150

    # This creates the vertical gap between separate notification boxes
    separator_height = 10

    # This ensures the gap is actually visible as empty space
    separator_color = frame

[urgency_low]
    timeout = 3

[urgency_normal]
    timeout = 1

[urgency_critical]
    timeout = 0
