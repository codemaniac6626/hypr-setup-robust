[global]
    # Default border outline styling
    frame_color = "${CT_DUNST_FRAME}"

[urgency_low]
    background = "${CT_DUNST_LOW_BG}"
    foreground = "${CT_THEME_WHITE}"

[urgency_normal]
    background = "${CT_WAYBAR_BG}"
    foreground = "${CT_THEME_WHITE}"

[urgency_critical]
    background = "${CT_THEME_DARK}"
    foreground = "${CT_THEME_WHITE}"
    frame_color = "${CT_DUNST_CRIT_FRAME}"
