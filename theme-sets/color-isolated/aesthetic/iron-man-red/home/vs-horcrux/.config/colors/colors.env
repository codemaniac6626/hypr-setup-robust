# ~/.config/colors/colors.env

### --- COMMON THEME COLORS (Shared Roles) --- ###
export CT_THEME_DARK="#111217"       # Master dark background role
export CT_THEME_BLACK="#000000"      # Pure pitch black
export CT_THEME_WHITE="#FFFFFF"      # Crisp text white
export CT_THEME_SURFACE="#1e2024"    # Component card / selected box grey
export CT_THEME_ACCENT="#fb342b"     # Your core signature Pink/Salmon accent
export CT_THEME_GREY="#333333"       # Alt text and border layout separators

### --- WAYBAR SPECIFIC COLORS --- ###
export CT_WAYBAR_BG="#330a00"        # Deep red/brown bar background
export CT_WAYBAR_FG_INACTIVE="#9e5858" # Dimmed red/brown text
export CT_WAYBAR_FG_COLOR="#ffe8e3"  # Soft light pinkish/white body text
export CT_WAYBAR_CRITICAL="#ff5555"  # Battery / power warning red

### --- DUNST SPECIFIC COLORS --- ###
export CT_DUNST_LOW_BG="#401717"     # Muted crimson background for low notifications
export CT_DUNST_FRAME="#813737"      # Default maroon window borders
export CT_DUNST_CRIT_FRAME="#BF616A" # Reddish frame highlight for urgent popups

# ~/.config/colors/colors.env

### --- HYPRLAND SPECIFIC STRING VARIABLES --- ###
# Stores the complete two-color gradient stream + the orientation angle rule
export CT_HYPR_ACTIVE_BORDER="rgba(ff0000ff) rgba(ffffff66) 45deg"

# Stores the complete fallback inactive background element border string
export CT_HYPR_INACTIVE_BORDER="rgba(595959aa)"

# Stores the drop-shadow depth alpha styling 
export CT_HYPR_SHADOW="rgba(1a1a1aee)"
export CT_HYPR_GAPS_IN=5
export CT_HYPR_GAPS_OUT=15
export CT_HYPR_BORDER_SIZE=2
export CT_HYPR_ROUNDING=5
